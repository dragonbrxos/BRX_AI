  "systems": {

    "interactive_station": {

      "description": "Objeto interativo no mundo que executa ações quando o jogador interage",

      "components": [
        "Model",
        "Parts",
        "SurfaceGui",
        "ProximityPrompt"
      ],

      "logic_patterns": {
        "interaction": "ProximityPrompt.Triggered",
        "animation_loop": "RunService.Heartbeat",
        "workspace_management": "remover duplicatas antes de criar"
      },

      "code_examples": {

        "create_part": "local p = Instance.new('Part'); p.Size = Vector3.new(4,1,4); p.Anchored = true; p.Parent = workspace",

        "create_prompt": "local prompt = Instance.new('ProximityPrompt'); prompt.ActionText='COMPRAR'; prompt.Parent = part",

        "interaction_logic": "prompt.Triggered:Connect(function(player) print(player.Name..' interagiu') end)"
      },

      "assembly_logic": [
        "criar Model",
        "criar base da estação com Parts",
        "adicionar SurfaceGui para interface",
        "adicionar ProximityPrompt para interação",
        "conectar lógica de compra"
      ],

      "possible_variations": [
        "Egg machine",
        "Loot box",
        "Pet machine",
        "Upgrade station",
        "Shop terminal"
      ]
    },

