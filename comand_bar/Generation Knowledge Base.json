  "generation_capability": {

    "description": "Combinando sistemas e regras é possível gerar scripts infinitos",

    "examples": [

      "interactive_station + pet_system = pet machine",

      "npc_character + enemy_ai = enemy npc",

      "weapon_system + energy_effects = magic sword",

